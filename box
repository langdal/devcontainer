#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/lib/allowlist.sh"
source "$SCRIPT_DIR/lib/secrets.sh"
source "$SCRIPT_DIR/lib/msb.sh"

DEFAULT_IMAGE="mcr.microsoft.com/devcontainers/base:ubuntu"
DEFAULT_ALLOWLIST="$SCRIPT_DIR/allowlist.default"
DIND_ALLOWLIST="$SCRIPT_DIR/allowlist.dind"
# Default image is auto-built from the bundled Dockerfile.box.base (devcontainers
# base + socat); docker mode uses the systemd+docker image. Both build on demand.
BASE_IMAGE="box-base:local"
BASE_DOCKERFILE="$SCRIPT_DIR/Dockerfile.box.base"
DOCKER_BASE_IMAGE="box-docker-base:local"
DOCKER_DOCKERFILE="$SCRIPT_DIR/Dockerfile.box.docker"

usage() {
  cat <<'EOF'
Usage: box [--net none|sanctioned|full] [--docker] [COMMAND]

  box                     Boot/attach the sandbox for this directory; open a shell.
  box --docker            Run with a Docker daemon inside the sandbox (auto-builds its image).
  box --port HOST:GUEST   Publish a guest port to the host (repeatable; PORT means PORT:PORT).
  box --host-port PORT    Allow the guest to reach a host service at host.docker.internal:PORT (repeatable).
  box -- CMD...           Run a one-off command in the sandbox.
  box shell               Attach an extra terminal to the running sandbox.
  box provision           Build step (open egress): install mise + tools into the volume.
  box provision --shell   Interactive open-egress root shell to add stuff manually.
  box provision -- CMD... One-off open-egress command (e.g. fetch from a non-allowlisted host).
  box build [TAG]         Build Dockerfile.box, load it into microsandbox, pin it in .box-image.
  box down                Stop the sandbox.
  box reset               Stop and remove the sandbox + named volumes.
  box --help              Show this help.

Egress modes: none (airgapped), sanctioned (default; deny + allowlist), full (provision).
Per-project egress extras: .box-allowlist   Secrets: .box-secrets
Base image: BOX_IMAGE env > .box-image file (project) > default. Use 'box build' for
system-level deps that must persist into runs (mise tools belong in mise.toml).
In provision --shell, only /mise, /home, and /workspace persist; install tools you
want to keep into /mise (e.g. mise use -g <tool>) or /home, not system-wide.
EOF
}

sandbox_name() { echo "box-$(basename "$PWD")"; }
state_dir() { echo "${XDG_STATE_HOME:-$HOME/.local/state}/box"; }
marker_file() { echo "$(state_dir)/$(sandbox_name).provisioned"; }
config_file() { echo "$(state_dir)/$(sandbox_name).config"; }

# A fingerprint of everything that affects the boot. If a re-run's fingerprint
# differs from the running sandbox's, box restarts it so the new config applies.
# (Reads the globals set in boot_or_attach.)
config_signature() {
  printf '%s\n' \
    "image=${IMAGE:-}" \
    "mode=${MODE:-}" \
    "docker=${BOX_DOCKER:-}" \
    "ports=${BOX_PORTS:-}" \
    "hostports=${BOX_HOST_PORTS:-}" \
    "secrets=${BOX_SECRETS:-}"
  printf 'host=%s\n' "${hosts[@]+"${hosts[@]}"}"
}
merged_hosts() {
  if [[ -n "${BOX_DOCKER_MODE:-}" ]]; then
    allowlist_merge "$DEFAULT_ALLOWLIST" "$DIND_ALLOWLIST" "$PWD/.box-allowlist"
  else
    allowlist_merge "$DEFAULT_ALLOWLIST" "$PWD/.box-allowlist"
  fi
}
declared_secrets() { secrets_parse "$PWD/.box-secrets"; }

# Image precedence: BOX_IMAGE env > .box-image file (first non-comment line) >
# the built default base (box-base:local, devcontainers base + socat).
resolve_image() {
  if [[ -n "${BOX_IMAGE:-}" ]]; then echo "$BOX_IMAGE"; return; fi
  if [[ -f "$PWD/.box-image" ]]; then
    local ref; ref="$(sed 's/#.*//' "$PWD/.box-image" | awk 'NF{print $1; exit}')"
    if [[ -n "$ref" ]]; then echo "$ref"; return; fi
  fi
  echo "$BASE_IMAGE"
}

# The image we intend to boot: docker mode (without an explicit BOX_IMAGE) uses
# the systemd+docker base; otherwise normal precedence.
effective_image() {
  if [[ -n "${BOX_DOCKER_MODE:-}" && -z "${BOX_IMAGE:-}" ]]; then
    echo "$DOCKER_BASE_IMAGE"
  else
    resolve_image
  fi
}

# build_base TAG DOCKERFILE -> host-build the bundled image, load it into msb.
build_base() {
  local tag="$1" dockerfile="$2" builder
  builder="$(box_builder)" || return 1
  echo "box: building $tag from $(basename "$dockerfile") with $builder (first use only)..." >&2
  _host "$builder" build -f "$dockerfile" -t "$tag" "$SCRIPT_DIR"
  msb_load_built "$builder" "$tag"
}

# ensure_image IMG -> make sure IMG is usable; echo the image to actually boot.
# Builds the bundled base/docker images on demand; user-provided images are left
# to msb to pull. The default base falls back to the plain pulled image (no socat)
# if no host builder is available. No builds under dry-run.
ensure_image() {
  local img="$1"
  [[ -n "${BOX_DRY_RUN:-}" ]] && { echo "$img"; return; }
  case "$img" in
    "$BASE_IMAGE")
      msb_image_exists "$BASE_IMAGE" && { echo "$BASE_IMAGE"; return; }
      if build_base "$BASE_IMAGE" "$BASE_DOCKERFILE"; then echo "$BASE_IMAGE"
      else
        echo "box: no docker/podman to build the base image; using $DEFAULT_IMAGE (no baked socat)." >&2
        echo "$DEFAULT_IMAGE"
      fi ;;
    "$DOCKER_BASE_IMAGE")
      msb_image_exists "$DOCKER_BASE_IMAGE" && { echo "$DOCKER_BASE_IMAGE"; return; }
      if build_base "$DOCKER_BASE_IMAGE" "$DOCKER_DOCKERFILE"; then echo "$DOCKER_BASE_IMAGE"
      else echo "box: --docker needs docker or podman to build $DOCKER_BASE_IMAGE (set BOX_BUILDER)." >&2; exit 1
      fi ;;
    *) echo "$img" ;;
  esac
}

# The image for this run, ensured present.
current_image() { ensure_image "$(effective_image)"; }

# Pick a host image builder: BOX_BUILDER env, else docker, else podman.
box_builder() {
  if [[ -n "${BOX_BUILDER:-}" ]]; then echo "$BOX_BUILDER"; return 0; fi
  local b
  for b in docker podman; do
    if command -v "$b" >/dev/null 2>&1; then echo "$b"; return 0; fi
  done
  return 1
}

# normalize_port SPEC -> a HOST:GUEST spec. A bare number becomes PORT:PORT;
# anything with a colon (HOST:GUEST, BIND:HOST:GUEST, /udp variants) passes through.
normalize_port() {
  if [[ "$1" =~ ^[0-9]+$ ]]; then echo "$1:$1"; else echo "$1"; fi
}

# _host CMD...  -> run a host command unless BOX_DRY_RUN is set, then just print.
_host() {
  if [[ -n "${BOX_DRY_RUN:-}" ]]; then printf 'host %s\n' "$*"; else "$@"; fi
}

# box build [TAG] — build Dockerfile.box, load it into microsandbox, pin .box-image.
do_build() {
  local tag="${1:-box-$(basename "$PWD"):local}"
  local df="$PWD/Dockerfile.box"
  [[ -f "$df" ]] || { echo "box: no Dockerfile.box in $PWD (copy the sample from the box repo; see README.box.md)" >&2; exit 1; }
  local builder
  builder="$(box_builder)" || { echo "box: need docker or podman to build an image (set BOX_BUILDER)" >&2; exit 1; }
  require_msb
  echo "box: building '$tag' from Dockerfile.box with $builder..." >&2
  _host "$builder" build -f "$df" -t "$tag" "$PWD"
  echo "box: loading '$tag' into microsandbox..." >&2
  msb_load_built "$builder" "$tag"
  if [[ -z "${BOX_IMAGE:-}" ]]; then
    echo "$tag" > "$PWD/.box-image"
    echo "box: pinned '$tag' in .box-image — run 'box' to use it." >&2
  else
    echo "box: BOX_IMAGE is set, so .box-image was not written." >&2
  fi
}

# Preflight: microsandbox must be installed before any real msb call.
# Skipped under BOX_DRY_RUN (the unit-test seam never touches a real binary).
require_msb() {
  [[ -n "${BOX_DRY_RUN:-}" ]] && return 0
  msb_available && return 0
  cat >&2 <<EOF
box: microsandbox ('msb') not found at '$MSB_BIN'.
Install it, then re-run:
  curl -fsSL https://install.microsandbox.dev | sh
msb installs to ~/.local/bin — make sure that directory is on your PATH.
If msb lives elsewhere, run box with MSB_BIN=/path/to/msb.
EOF
  exit 1
}

# Always provisions with OPEN egress (msb_provision forces full); mode flags do not apply here.
do_provision() { require_msb; msb_provision "$(current_image)" "$PWD"; }
mark_provisioned() { mkdir -p "$(state_dir)"; : > "$(marker_file)"; }

ensure_provisioned() {
  [[ -n "${BOX_ASSUME_PROVISIONED:-}" ]] && return 0
  # TODO(prototype): marker can go stale if named volumes are removed outside 'box reset'.
  [[ -f "$(marker_file)" ]] && return 0
  echo "box: first run for $(sandbox_name); provisioning (open egress)..." >&2
  do_provision
  mark_provisioned
}

boot_or_attach() {  # MODE -- CMD...
  local mode="$1"; shift
  if [[ "${1:-}" == "--" ]]; then shift; fi
  local cmd=("$@")
  local name; name="$(sandbox_name)"
  require_msb
  [[ -n "${BOX_DOCKER_MODE:-}" ]] && { BOX_DOCKER=1; export BOX_DOCKER; }
  IMAGE="$(current_image)"
  ensure_provisioned
  BOX_SECRETS="$(declared_secrets)"; export BOX_SECRETS
  if [[ ${#PORTS[@]} -gt 0 ]]; then BOX_PORTS="$(printf '%s\n' "${PORTS[@]}")"; else BOX_PORTS=""; fi
  export BOX_PORTS
  if [[ ${#HOST_PORTS[@]} -gt 0 ]]; then BOX_HOST_PORTS="$(IFS=,; echo "${HOST_PORTS[*]}")"; else BOX_HOST_PORTS=""; fi
  export BOX_HOST_PORTS
  mapfile -t hosts < <(merged_hosts)
  local sig; sig="$(config_signature)"
  if msb_is_running "$name"; then
    if [[ "$(cat "$(config_file)" 2>/dev/null || true)" != "$sig" ]]; then
      echo "box: run configuration changed since last start; restarting the sandbox to apply it..." >&2
      msb_stop "$name" || true
      boot_fresh "$name" "$mode" "$sig"
    fi
  else
    boot_fresh "$name" "$mode" "$sig"
  fi
  msb_attach "$name" -- "${cmd[@]}"
}

# boot_fresh NAME MODE SIG -> boot a new sandbox with the current config and
# record its fingerprint. (Reads globals IMAGE, hosts, BOX_DOCKER, BOX_HOST_PORTS.)
boot_fresh() {
  local name="$1" mode="$2" sig="$3"
  msb_up "$name" "$IMAGE" "$PWD" "$mode" "${hosts[@]}"
  if [[ -n "${BOX_DOCKER:-}" ]]; then
    echo "box: waiting for dockerd to start inside the sandbox..." >&2
    msb_docker_wait "$name"
  fi
  if [[ -n "${BOX_HOST_PORTS:-}" ]]; then
    msb_host_alias "$name"
    echo "box: host reachable at host.docker.internal:<port> (allowed ports: $BOX_HOST_PORTS)" >&2
  fi
  mkdir -p "$(state_dir)"; printf '%s' "$sig" > "$(config_file)"
}

# Docker-in-sandbox mode: enabled by the --docker flag or a .box-docker marker.
BOX_DOCKER_MODE=""
[[ -f "$PWD/.box-docker" ]] && BOX_DOCKER_MODE=1

PORTS=()
HOST_PORTS=()
MODE="sanctioned"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    --docker) BOX_DOCKER_MODE=1; shift ;;
    --port)
      [[ $# -ge 2 ]] || { echo "box: --port requires an argument (PORT or HOST:GUEST)" >&2; exit 2; }
      PORTS+=("$(normalize_port "$2")"); shift 2 ;;
    --host-port)
      [[ $# -ge 2 ]] || { echo "box: --host-port requires a port number" >&2; exit 2; }
      [[ "$2" =~ ^[0-9]+$ ]] || { echo "box: --host-port must be a port number, got '$2'" >&2; exit 2; }
      HOST_PORTS+=("$2"); shift 2 ;;
    build) shift; do_build "${1:-}"; exit 0 ;;
    --net)
      [[ $# -ge 2 ]] || { echo "box: --net requires an argument (none|sanctioned|full)" >&2; exit 2; }
      case "$2" in
        none|sanctioned|full) ;;
        *) echo "box: unknown --net value '$2' (none|sanctioned|full)" >&2; exit 2 ;;
      esac
      MODE="$2"; shift 2 ;;
    provision)
      case "${2:-}" in
        --shell|-i) require_msb; msb_provision_shell "$(current_image)" "$PWD"; exit 0 ;;
        --) shift 2; require_msb; msb_provision_shell "$(current_image)" "$PWD" "$@"; exit 0 ;;
        *) do_provision; mark_provisioned; exit 0 ;;
      esac ;;
    down) msb_stop "$(sandbox_name)" || true; exit 0 ;;
    reset)
      msb_stop "$(sandbox_name)" 2>/dev/null || true
      msb_remove "$(sandbox_name)" 2>/dev/null || true
      rm -f "$(marker_file)" "$(config_file)"
      echo "box: removed sandbox + marker (volumes: msb volume rm box-mise box-home)"
      exit 0 ;;
    shell) boot_or_attach "$MODE" -- /usr/bin/zsh; exit 0 ;;
    --) shift; boot_or_attach "$MODE" -- "$@"; exit 0 ;;
    *) echo "box: unknown argument '$1' (try --help)" >&2; exit 2 ;;
  esac
done

boot_or_attach "$MODE" -- /usr/bin/zsh
