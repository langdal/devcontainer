#!/usr/bin/env bash
set -euo pipefail

# Resolve the real directory of this script, following symlinks.
# Needed so --build finds the Dockerfile when invoked via an installed symlink.
resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "$source" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" && pwd
}
SCRIPT_DIR="$(resolve_script_dir)"

IMAGE_NAME="generic-devcontainer"

# Flags
DRY_RUN=false
FORCE_BUILD=false
DEFAULT_PORTS=false
MAINTENANCE=false
MONITOR=false
MONITOR_FW=false
DISABLE_FW=false
ENABLE_FW=false
EXTRA_PORTS=()
CMD_ARGS=()

usage() {
  cat <<EOF
Usage: dev [OPTIONS] [-- COMMAND...]
       dev install

Run or attach to the generic devcontainer.

OPTIONS:
  --help          Show this help message
  --dry-run       Print docker command without executing
  --build         Force rebuild the image
  --port PORT     Add additional port forwarding (repeatable)
  --default-ports Forward the default development ports (5173, 5174, 8080,
                  2345, 3000). Off by default.
  --maintenance   Start with firewall disabled and sudo enabled.
                  Container name is suffixed with -maint to avoid
                  clashing with the normal container.
  --monitor       Tail the firewall proxy log of the running container
                  (/var/log/tinyproxy.log). Does not start a container.
  --monitor-fw    Stream packets dropped by iptables in the running container
                  (tcpdump on NFLOG group 1). Does not start a container.
  --disable-firewall
                  Open the firewall on the running container: flush OUTPUT
                  rules + ACCEPT policy, and switch tinyproxy to an allow-all
                  filter (SIGHUP reload). Existing shells keep working
                  whether or not HTTPS_PROXY is set.
  --enable-firewall
                  Re-run firewall-init.sh on the running container to rebuild
                  the allowlist filter and restore the default-deny iptables
                  policy.
  --              Pass remaining arguments as command to container

COMMANDS:
  install         Symlink this script into a writable directory on PATH

EXAMPLES:
  dev                           # Start or attach to container with default shell
  dev --build                   # Rebuild image and start container
  dev --dry-run                 # Show docker command without running
  dev --port 9000 --port 9001   # Add custom port forwarding
  dev --default-ports           # Forward the default dev ports
  dev --maintenance             # Start in maintenance mode (no firewall, sudo enabled)
  dev --monitor                 # Tail firewall proxy log of running container
  dev --monitor-fw              # Stream iptables-dropped packets of running container
  dev --disable-firewall        # Drop the firewall on the running container
  dev --enable-firewall         # Restore the firewall on the running container
  dev -- npm run dev            # Run custom command in container
  dev install                   # Install 'dev' onto your PATH

EOF
}

install_self() {
  local script_path
  script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  local target_dir=""
  local candidates=("$HOME/.local/bin" "$HOME/bin" "/usr/local/bin")
  for dir in "${candidates[@]}"; do
    case ":$PATH:" in
      *":$dir:"*)
        if [[ -d "$dir" && -w "$dir" ]]; then
          target_dir="$dir"
          break
        fi
        ;;
    esac
  done

  if [[ -z "$target_dir" ]]; then
    echo "Error: No writable bin directory found on PATH." >&2
    echo "Expected one of: ${candidates[*]}" >&2
    echo "Create one and add it to PATH, then retry." >&2
    exit 1
  fi

  local link="$target_dir/dev"
  if [[ -L "$link" ]]; then
    local current
    current="$(readlink "$link")"
    if [[ "$current" == "$script_path" ]]; then
      echo "Already installed: $link -> $script_path"
    else
      echo "Error: $link already exists and points to $current" >&2
      echo "Remove it first: rm $link" >&2
      exit 1
    fi
  elif [[ -e "$link" ]]; then
    echo "Error: $link exists and is not a symlink. Refusing to overwrite." >&2
    exit 1
  else
    ln -s "$script_path" "$link"
    echo "Installed: $link -> $script_path"
  fi

  local zshrc="$HOME/.zshrc"
  local compdef_line='compdef _gnu_generic dev'
  if [[ -f "$zshrc" ]] && grep -qxF -- "$compdef_line" "$zshrc"; then
    echo "zsh completion already configured in ~/.zshrc"
    return
  fi

  if [[ ! -t 0 ]]; then
    echo "To enable tab-completion, add this line to ~/.zshrc:  $compdef_line"
    return
  fi

  local reply
  read -r -p "Add '$compdef_line' to ~/.zshrc to enable tab-completion? [y/N] " reply
  case "$reply" in
    y|Y|yes|YES)
      {
        echo ""
        echo "# Added by 'dev install': enable tab-completion for the dev script"
        echo "$compdef_line"
      } >> "$zshrc"
      echo "Added compdef line to ~/.zshrc. Run 'exec zsh' to activate."
      ;;
    *)
      echo "Skipped. You can add it later with: echo '$compdef_line' >> ~/.zshrc"
      ;;
  esac
}

# Handle subcommands before flag parsing
if [[ ${1:-} == "install" ]]; then
  install_self
  exit 0
fi

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --help)
      usage
      exit 0
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --build)
      FORCE_BUILD=true
      shift
      ;;
    --port)
      if [[ -z ${2:-} ]]; then
        echo "Error: --port requires a port number" >&2
        exit 1
      fi
      EXTRA_PORTS+=("$2")
      shift 2
      ;;
    --default-ports)
      DEFAULT_PORTS=true
      shift
      ;;
    --maintenance)
      MAINTENANCE=true
      shift
      ;;
    --monitor)
      MONITOR=true
      shift
      ;;
    --monitor-fw)
      MONITOR_FW=true
      shift
      ;;
    --disable-firewall)
      DISABLE_FW=true
      shift
      ;;
    --enable-firewall)
      ENABLE_FW=true
      shift
      ;;
    --)
      shift
      CMD_ARGS=("$@")
      break
      ;;
    *)
      echo "Error: Unknown option: $1" >&2
      echo "Run 'dev --help' for usage information" >&2
      exit 1
      ;;
  esac
done

# Container naming: normal mode uses dev-<dir>, maintenance uses dev-<dir>-maint.
# Refuse to start one mode while the other is already running for the same
# workspace — both would share /workspace and produce surprising state.
WORKSPACE_BASENAME="$(basename "$(pwd)")"
NORMAL_NAME="dev-${WORKSPACE_BASENAME}"
MAINT_NAME="dev-${WORKSPACE_BASENAME}-maint"

# --monitor / --monitor-fw: read firewall logs from the running normal container.
# Maintenance mode has no firewall, so these are meaningless there.
if [[ "$MONITOR" == true || "$MONITOR_FW" == true ]]; then
  if [[ "$MONITOR" == true && "$MONITOR_FW" == true ]]; then
    echo "Error: --monitor and --monitor-fw are mutually exclusive." >&2
    exit 1
  fi
  if [[ "$MAINTENANCE" == true ]]; then
    echo "Error: --monitor* and --maintenance are mutually exclusive (no firewall in maintenance mode)." >&2
    exit 1
  fi
  if ! docker ps -q -f name="^${NORMAL_NAME}$" | grep -q .; then
    echo "Error: container ${NORMAL_NAME} is not running. Start it with 'dev' first." >&2
    exit 1
  fi
  if [[ "$MONITOR" == true ]]; then
    exec docker exec -it "$NORMAL_NAME" tail -F /var/log/tinyproxy.log
  else
    # tcpdump on the NFLOG group set by firewall-init.sh. Needs CAP_NET_ADMIN
    # (the container already has it) and root inside the container.
    exec docker exec -it --user root "$NORMAL_NAME" \
        tcpdump -i nflog:1 -nn -l
  fi
fi

# --disable-firewall / --enable-firewall: toggle iptables on the running normal
# container without restarting it. Container has CAP_NET_ADMIN, so root inside
# can rewrite the OUTPUT chain.
if [[ "$DISABLE_FW" == true || "$ENABLE_FW" == true ]]; then
  if [[ "$DISABLE_FW" == true && "$ENABLE_FW" == true ]]; then
    echo "Error: --disable-firewall and --enable-firewall are mutually exclusive." >&2
    exit 1
  fi
  if [[ "$MAINTENANCE" == true ]]; then
    echo "Error: --disable-firewall/--enable-firewall and --maintenance are mutually exclusive (no firewall in maintenance mode)." >&2
    exit 1
  fi
  if ! docker ps -q -f name="^${NORMAL_NAME}$" | grep -q .; then
    echo "Error: container ${NORMAL_NAME} is not running. Start it with 'dev' first." >&2
    exit 1
  fi
  if [[ "$DISABLE_FW" == true ]]; then
    # Open the kernel egress AND switch tinyproxy to allow-all (permissive
    # filter + SIGHUP) so HTTP_PROXY-honoring clients in existing shells
    # also get through, not just direct/--noproxy traffic.
    exec docker exec --user root "$NORMAL_NAME" sh -c "
      set -e
      iptables -F OUTPUT
      iptables -P OUTPUT ACCEPT
      printf '%s\n' '^.*\$' > /etc/tinyproxy/filter
      if [ -f /run/tinyproxy.pid ]; then
          kill -HUP \"\$(cat /run/tinyproxy.pid)\"
      else
          pkill -HUP -x tinyproxy 2>/dev/null || true
      fi
      echo 'firewall disabled'
    "
  else
    exec docker exec --user root "$NORMAL_NAME" /usr/local/sbin/firewall-init.sh
  fi
fi

if [[ "$MAINTENANCE" == true ]]; then
  if docker ps -q -f name="^${NORMAL_NAME}$" | grep -q .; then
    echo "Error: normal container ${NORMAL_NAME} is running for this workspace." >&2
    echo "       Stop it first:  docker stop ${NORMAL_NAME}" >&2
    exit 1
  fi
  CONTAINER_NAME="$MAINT_NAME"
else
  if docker ps -q -f name="^${MAINT_NAME}$" | grep -q .; then
    echo "Error: maintenance container ${MAINT_NAME} is running for this workspace." >&2
    echo "       Stop it first:  docker stop ${MAINT_NAME}" >&2
    exit 1
  fi
  CONTAINER_NAME="$NORMAL_NAME"
fi

# Build image if needed
if [[ "$FORCE_BUILD" == true ]] || ! docker images -q "$IMAGE_NAME" | grep -q .; then
  if [[ "$DRY_RUN" == true ]]; then
    echo "Would build image: docker buildx build --network=host -t $IMAGE_NAME $SCRIPT_DIR"
  else
    echo "Building image $IMAGE_NAME..."
    docker buildx build --network=host -t "$IMAGE_NAME" "$SCRIPT_DIR"
  fi
fi

# Check if container exists and is running
if [[ "$DRY_RUN" == false ]]; then
  if docker ps -q -f name="^${CONTAINER_NAME}$" | grep -q .; then
    # Container exists and is running
    echo "Attaching to running container $CONTAINER_NAME..."
    if [[ ${#CMD_ARGS[@]} -gt 0 ]]; then
      exec docker exec -it "$CONTAINER_NAME" "${CMD_ARGS[@]}"
    else
      exec docker exec -it "$CONTAINER_NAME" zsh
    fi
  elif docker ps -aq -f name="^${CONTAINER_NAME}$" | grep -q .; then
    # Container exists but is stopped
    echo "Starting stopped container $CONTAINER_NAME..."
    docker start "$CONTAINER_NAME"
    if [[ ${#CMD_ARGS[@]} -gt 0 ]]; then
      exec docker exec -it "$CONTAINER_NAME" "${CMD_ARGS[@]}"
    else
      exec docker exec -it "$CONTAINER_NAME" zsh
    fi
  fi
fi

# Build docker run command
DOCKER_CMD=(docker run -it --rm --name "$CONTAINER_NAME")

# Capability needed by entrypoint to configure iptables (used in normal mode;
# harmless when unused in maintenance mode).
DOCKER_CMD+=(--cap-add=NET_ADMIN)

# Volume mounts
DOCKER_CMD+=(-v "$(pwd):/workspace")
DOCKER_CMD+=(-v devcontainer-mise:/mise)
DOCKER_CMD+=(-v devcontainer-home:/home/vscode)

# Skip default ports if another dev-* container is already running (they'd collide).
# Explicit --port requests are left alone so conflicts there still surface.
if [[ "$DEFAULT_PORTS" == true ]]; then
  OTHER_DEV=$(docker ps --format '{{.Names}}' | grep '^dev-' | grep -vx "$CONTAINER_NAME" || true)
  if [[ -n "$OTHER_DEV" ]]; then
    echo "Note: another dev container is running ($(echo "$OTHER_DEV" | paste -sd, -)); skipping default port forwards." >&2
    DEFAULT_PORTS=false
  fi
fi

# Port forwarding
if [[ "$DEFAULT_PORTS" == true ]]; then
  DOCKER_CMD+=(-p 5173:5173 -p 5174:5174 -p 8080:8080 -p 2345:2345 -p 3000:3000)
fi

# Extra ports
if [[ ${#EXTRA_PORTS[@]} -gt 0 ]]; then
  for port in "${EXTRA_PORTS[@]}"; do
    DOCKER_CMD+=(-p "$port:$port")
  done
fi

# Forward GITHUB_TOKEN if set
if [[ -n ${GITHUB_TOKEN:-} ]]; then
  DOCKER_CMD+=(-e GITHUB_TOKEN)
fi

# Maintenance mode: tell entrypoint.sh to skip firewall init and grant sudo.
if [[ "$MAINTENANCE" == true ]]; then
  DOCKER_CMD+=(-e DEVCONTAINER_MAINTENANCE=1)
fi

# Image name
DOCKER_CMD+=("$IMAGE_NAME")

# Command args (default to zsh if none provided)
if [[ ${#CMD_ARGS[@]} -gt 0 ]]; then
  DOCKER_CMD+=("${CMD_ARGS[@]}")
else
  DOCKER_CMD+=(zsh)
fi

# Execute or print
if [[ "$DRY_RUN" == true ]]; then
  echo "${DOCKER_CMD[*]}"
else
  exec "${DOCKER_CMD[@]}"
fi
